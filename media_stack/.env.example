# Media Stack Configuration
# Secrets - keep private

# Timezone
TZ=America/New_York

# User/Group IDs
# Match the owner of /mnt/media/ directories
PUID=1000
PGID=1000

# Gluetun VPN Configuration
# See https://github.com/qdm12/gluetun-wiki for all options
# VPN_SERVICE_PROVIDER=
# VPN_TYPE=
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# WIREGUARD_DNS=

# OpenVPN alternative (uncomment and configure instead of WireGuard):
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# OPENVPN_PROVIDER=

# Tailscale
TS_AUTHKEY=tskey-auth-YOUR_AUTH_KEY
TAILNET_NAME=your-tailnet-name
