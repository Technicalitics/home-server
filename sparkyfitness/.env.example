# SparkyFitness Configuration
# Secrets - keep private

# Database
# Generate with: openssl rand -hex 32
SPARKY_FITNESS_DB_NAME=sparkyfitness_db
SPARKY_FITNESS_DB_USER=sparky
SPARKY_FITNESS_DB_PASSWORD=CHANGE_ME
SPARKY_FITNESS_APP_DB_USER=sparky_app
SPARKY_FITNESS_APP_DB_PASSWORD=CHANGE_ME

# Security
# Generate with: openssl rand -hex 32
SPARKY_FITNESS_API_ENCRYPTION_KEY=CHANGE_ME
BETTER_AUTH_SECRET=CHANGE_ME

# OIDC (Authentik)
# Create an OAuth provider in Authentik with:
# - Redirect URIs: https://fit.<TAILNET_NAME>.ts.net/api/auth/callback/oidc
# - Signing Key: default
SPARKY_FITNESS_OIDC_CLIENT_ID=CHANGE_ME
SPARKY_FITNESS_OIDC_CLIENT_SECRET=CHANGE_ME

# Timezone
TZ=Etc/UTC

# Tailscale
TS_AUTHKEY=tskey-auth-YOUR_AUTH_KEY
TAILNET_NAME=your-tailnet-name
