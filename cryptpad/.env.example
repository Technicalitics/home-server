# CryptPad Configuration
# Secrets - keep private

# Timezone (optional, defaults to UTC)
TZ=UTC

# CryptPad image tag (optional, defaults to latest)
CRYPTPAD_TAG=version-2026.2.0

# Enable OnlyOffice for better Office format compatibility (optional)
# Read and accept the license: https://github.com/ONLYOFFICE/web-apps/blob/master/LICENSE.txt
# CPAD_INSTALL_ONLYOFFICE=yes

# NetBird Setup Key
NB_SETUP_KEY=
