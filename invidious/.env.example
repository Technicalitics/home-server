# Invidious Configuration
# Secrets - keep private

# Database
POSTGRES_USER=kemal
POSTGRES_PASSWORD=kemal
POSTGRES_DB=invidious

# Invidious Secrets
# IMPORTANT: Generate new keys with: pwgen -s 16 1 (use -s for alphanumeric only)
# HMAC_KEY - Secret key for Invidious
# INVIDIOUS_COMPANION_KEY - Secret key for Invidious companion
# SERVER_SECRET_KEY - Secret key for Invidious companion server
HMAC_KEY=CHANGE_ME_PWGEN_16_1
INVIDIOUS_COMPANION_KEY=CHANGE_ME_PWGEN_16_1

# Tailscale
TS_AUTHKEY=tskey-auth-YOUR_AUTH_KEY
TAILNET_NAME=your-tailnet-name
