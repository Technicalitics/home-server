# Authentik Configuration
# Secrets - keep private

# Image version (optional - defaults to latest RC)
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.2.1-rc1

# PostgreSQL credentials
POSTGRES_USER=USER_NAME
PG_PASS=PASSWORD
POSTGRES_DB=DATABASE_NAME

# Authentik secret key (generate with: openssl rand -base64 60)
AUTHENTIK_SECRET_KEY=SECRET

# Custom ports (optional - uncomment to use standard ports)
# COMPOSE_PORT_HTTP=80
# COMPOSE_PORT_HTTPS=443

# Tailscale
TS_AUTHKEY=tskey-auth-YOUR_AUTH_KEY
TAILNET_NAME=your-tailnet-name
