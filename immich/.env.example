# Immich Configuration
# Secrets - keep private

# Immich Version
IMMICH_VERSION=release

# Upload location (photos library)
UPLOAD_LOCATION=/path/to/photos

# Database location
DB_DATA_LOCATION=/path/to/database

# Database credentials
DB_USERNAME=DB_USERNAME
DB_PASSWORD=DB_PASSWORD
DB_DATABASE_NAME=DB_DATABASE_NAME
DB_HOSTNAME=127.0.0.1

# Redis password (optional, leave empty if not using auth)
REDIS_PASSWORD=
REDIS_HOSTNAME=127.0.0.1

# Tailscale
TS_AUTHKEY=tskey-auth-YOUR_AUTH_KEY
TAILNET_NAME=your-tailnet-name
